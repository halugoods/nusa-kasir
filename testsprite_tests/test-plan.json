    "priority": "Medium",
    "steps": [
      {"type": "action", "description": "Go to checkout with empty cart → tap Bayar"},
      {"type": "assertion", "description": "'Keranjang kosong' error toast"},
      {"type": "action", "description": "Add item, go to checkout, enter cash < total → tap Bayar"},
      {"type": "assertion", "description": "'Jumlah dibayarkan kurang' error toast"}
